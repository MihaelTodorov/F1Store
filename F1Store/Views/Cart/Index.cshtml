@model IEnumerable<F1Store.Models.Cart.CartItemVM>

@{
    ViewData["Title"] = "Shopping Cart";
    string Eur(decimal x) => $"{x:0.00} €";
    var items = Model?.ToList() ?? new List<F1Store.Models.Cart.CartItemVM>();
    var total = items.Sum(x => x.Subtotal);
}

<div class="pf-cart-page container py-5">
    <div class="pf-cart-page-head mb-5 text-center">
        <h1 class="f1-font text-danger display-4 mb-2">
            <i class="bi bi-cart3 me-3"></i>SHOPPING CART
        </h1>
        <p class="text-secondary uppercase">@items.Count ITEM(S) IN YOUR PADDOCK</p>

        <div class="mt-4">
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-light f1-font btn-sm px-4">
                <i class="bi bi-arrow-left me-2"></i>CONTINUE SHOPPING
            </a>
        </div>
    </div>

    @if (!items.Any())
    {
        <div class="text-center py-5 border border-secondary rounded bg-dark bg-opacity-50">
            <div class="display-1 text-secondary mb-4"><i class="bi bi-cart-x"></i></div>
            <h2 class="f1-font">YOUR CART IS EMPTY</h2>
            <a asp-controller="Product" asp-action="Index" class="btn btn-danger f1-font px-5 py-3 mt-3">
                BROWSE PRODUCTS
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-xl-8">
                <div class="card bg-dark border-secondary rounded-0">
                    <div class="card-header bg-secondary bg-opacity-25 border-secondary py-3">
                        <span class="f1-font small fw-bold">SELECTED ITEMS</span>
                    </div>
                    <div class="card-body p-0">
                        @foreach (var item in items)
                        {
                            <div class="d-flex align-items-center p-3 border-bottom border-secondary gap-3 @(item.IsOutOfStock ? "opacity-50" : "")">
                                <div class="cart-img-wrap" style="width: 100px;">
                                    <img src="@item.Picture" class="img-fluid rounded" alt="@item.ProductName" />
                                </div>

                                <div class="flex-grow-1">
                                    <h5 class="f1-font mb-1" style="font-size: 1rem;">@item.ProductName</h5>
                                    <div class="small text-muted mb-2">UNIT: @Eur(item.FinalUnitPrice)</div>

                                    @if (!item.IsOutOfStock)
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            @* Форма за НАМАЛЯВАНЕ на количеството *@
                                            <form asp-action="UpdateQuantity" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                                <input type="hidden" name="delta" value="-1" />
                                                <button type="submit" class="btn btn-outline-secondary text-white px-2 btn-sm" @(item.Quantity <= 1 ? "disabled" : "")>-</button>
                                            </form>

                                            <span class="f1-font text-white px-2">@item.Quantity</span>

                                            @* Форма за УВЕЛИЧАВАНЕ на количеството *@
                                            <form asp-action="UpdateQuantity" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                                <input type="hidden" name="delta" value="1" />
                                                <button type="submit" class="btn btn-outline-secondary text-white px-2 btn-sm" @(item.Quantity >= item.AvailableQuantity ? "disabled" : "")>+</button>
                                            </form>

                                            <small class="text-muted opacity-50 ms-2" style="font-size: 0.7rem;">AVAIL: @item.AvailableQuantity</small>
                                        </div>
                                    }
                                </div>

                                <div class="text-end px-3">
                                    <div class="f1-font text-white">@Eur(item.Subtotal)</div>
                                    @* Работещият бутон за премахване *@
                                    <form asp-action="Remove" method="post" class="mt-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                        <button type="submit" class="btn btn-link text-danger p-0 small text-decoration-none">REMOVE</button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="mt-4 text-end">
                    @* Поправеният бутон за изчистване на всичко *@
                    <form asp-action="ClearEntireCart" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger f1-font">
                            <i class="bi bi-trash3 me-2"></i>CLEAR ENTIRE CART
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="card bg-dark border-danger rounded-0 shadow-lg">
                    <div class="card-body p-4">
                        <h4 class="f1-font text-white mb-4 border-bottom border-secondary pb-2">ORDER SUMMARY</h4>
                        <div class="d-flex justify-content-between mb-3 text-muted">
                            <span>SUBTOTAL</span>
                            <span>@Eur(total)</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4 border-top border-secondary pt-3 text-white">
                            <span class="f1-font fs-5">TOTAL</span>
                            <span class="f1-font fs-4 text-danger">@Eur(total)</span>
                        </div>

                        <form asp-action="Checkout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger w-100 f1-font py-3 fs-5" @(!items.Any() ? "disabled" : "")>
                                <i class="bi bi-bag-check me-2"></i>CHECKOUT
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .f1-font {
        font-family: 'Orbitron', sans-serif;
        letter-spacing: 1px;
    }

    .card {
        background-color: rgba(21, 21, 30, 0.9) !important;
    }

    .btn-danger {
        background-color: #e10600;
        border: none;
        border-radius: 0;
    }

    .btn-outline-light {
        border-radius: 0;
    }
</style>