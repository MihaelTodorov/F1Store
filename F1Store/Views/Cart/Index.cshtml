@model IEnumerable<F1Store.Models.Cart.CartItemVM>

@{
    ViewData["Title"] = "Shopping Cart";
    string Eur(decimal x) => $"{x:0.00} €";
    var items = Model?.ToList() ?? new List<F1Store.Models.Cart.CartItemVM>();
    var total = items.Sum(x => x.Subtotal);
}

<div class="pf-cart-page container py-5">
    <div class="pf-cart-page-head mb-5 text-center">
        <h1 class="f1-font text-danger display-4 mb-2">
            <i class="bi bi-cart3 me-3"></i>SHOPPING CART
        </h1>
        <p class="text-secondary uppercase">@items.Count ITEM(S) IN YOUR PADDOCK</p>

        <div class="mt-4">
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-light f1-font btn-sm px-4">
                <i class="bi bi-arrow-left me-2"></i>CONTINUE SHOPPING
            </a>
        </div>
    </div>

    @if (!items.Any())
    {
        <div class="text-center py-5 border border-secondary rounded bg-dark bg-opacity-50">
            <div class="display-1 text-secondary mb-4"><i class="bi bi-cart-x"></i></div>
            <h2 class="f1-font">YOUR CART IS EMPTY</h2>
            <p class="text-muted mb-4">Add some gear to your cart and come back to checkout.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-danger f1-font px-5 py-3">
                BROWSE PRODUCTS
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-xl-8">
                <div class="card bg-dark border-secondary rounded-0">
                    <div class="card-header bg-secondary bg-opacity-25 border-secondary py-3">
                        <span class="f1-font small fw-bold">SELECTED ITEMS</span>
                    </div>
                    <div class="card-body p-0">
                        @foreach (var item in items)
                        {
                            <div class="d-flex align-items-center p-3 border-bottom border-secondary gap-3">
                                <div class="cart-img-wrap" style="width: 100px;">
                                    @if (!string.IsNullOrWhiteSpace(item.Picture))
                                    {
                                        <img src="@item.Picture" class="img-fluid rounded" alt="@item.ProductName" />
                                    }
                                    else
                                    {
                                        <div class="bg-secondary bg-opacity-50 text-center py-3 rounded"><i class="bi bi-image fs-2"></i></div>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="f1-font mb-1" style="font-size: 1rem;">@item.ProductName</h5>
                                    <div class="small text-muted">UNIT: @Eur(item.FinalUnitPrice)</div>
                                </div>
                                <div class="text-end px-3">
                                    <div class="f1-font text-white">@Eur(item.Subtotal)</div>
                                    <form asp-controller="Cart" asp-action="Remove" method="post" class="mt-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                        <button type="submit" class="btn btn-link text-danger p-0 small">REMOVE</button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <form asp-controller="Cart" asp-action="Clear" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger f1-font">
                            <i class="bi bi-trash3 me-2"></i>CLEAR ENTIRE CART
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="card bg-dark border-danger rounded-0 shadow-lg">
                    <div class="card-body p-4">
                        <h4 class="f1-font text-white mb-4 border-bottom border-secondary pb-2">ORDER SUMMARY</h4>
                        <div class="d-flex justify-content-between mb-3 text-muted">
                            <span>SUBTOTAL</span>
                            <span>@Eur(total)</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 text-muted">
                            <span>DELIVERY</span>
                            <span class="small">CALCULATED NEXT</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4 border-top border-secondary pt-3">
                            <span class="f1-font fs-5">TOTAL</span>
                            <span class="f1-font fs-4 text-danger">@Eur(total)</span>
                        </div>

                        <form asp-controller="Cart" asp-action="Checkout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger w-100 f1-font py-3 fs-5 shadow">
                                <i class="bi bi-bag-check me-2"></i>CHECKOUT
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @* Тук можеш да запазиш твоя оригинален скрипт за UpdateQuantityAjax, ако ти трябва *@
}

<style>
    /* ПРЕМАХВАМЕ тъмните overlay-и, които правеха страницата невидима */
    .pf-cart-page {
        position: relative;
        z-index: 5;
    }

    .f1-font {
        font-family: 'Orbitron', sans-serif;
        letter-spacing: 1px;
    }

    .uppercase {
        text-transform: uppercase;
    }

    /* Дизайн на количката */
    .card {
        background-color: rgba(21, 21, 30, 0.8) !important;
        backdrop-filter: blur(5px);
    }

    /* Оправяме видимостта на иконите и заглавията */
    h1, h2, h3, h4, h5 {
        color: white !important;
    }

    .text-muted {
        color: #adb5bd !important;
    }

    /* Бутон за количка в стил F1 */
    .btn-danger {
        background-color: #e10600;
        border: none;
        border-radius: 0;
        transition: 0.3s;
    }

        .btn-danger:hover {
            background-color: #ff1e1e;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(225, 6, 0, 0.4);
        }

    .btn-outline-light {
        border-radius: 0;
        border-width: 2px;
    }
</style>