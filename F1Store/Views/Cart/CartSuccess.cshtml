@model F1Store.Models.Cart.CartCheckoutSuccessVM

@{
    ViewData["Title"] = "Order completed";

    // Помощна функция за форматиране на валута
    string Eur(decimal x) => $"{x:0.00} €";
}

<section class="pf-order-success-page">
    <div class="container-fluid px-3">
        <div class="pf-order-success-hero">
            <div class="pf-order-success-kicker">Order confirmed</div>

            <div class="pf-order-success-title-row">
                <div class="pf-order-success-icon">
                    <i class="bi bi-check2-circle"></i>
                </div>

                <div>
                    <h1 class="pf-order-success-title">Order completed successfully</h1>
                    <p class="pf-order-success-subtitle">
                        Your order has been placed and your cart has been checked out successfully.
                    </p>
                </div>
            </div>

            <div class="pf-order-success-meta">
                <div class="pf-order-success-meta-item">
                    <span class="pf-order-success-meta-label">Order date</span>
                    @* Показваме датата от модела *@
                    <span class="pf-order-success-meta-value">@Model.OrderDate</span>
                </div>

                <div class="pf-order-success-meta-item">
                    <span class="pf-order-success-meta-label">Order ID</span>
                    @* Коригирано на OrderGroupId според контролера ти *@
                    <span class="pf-order-success-meta-value">#@Model.OrderGroupId</span>
                </div>

                <div class="pf-order-success-meta-item">
                    <span class="pf-order-success-meta-label">Total</span>
                    <span class="pf-order-success-meta-value">@Eur(Model.TotalAmount)</span>
                </div>
            </div>

            <div class="pf-order-success-actions">
                <a asp-controller="Order" asp-action="MyOrders" class="pf-order-action-btn pf-order-action-btn--primary">
                    <i class="bi bi-bag-check me-2"></i>
                    <span>View My Orders</span>
                </a>

                <a asp-controller="Product" asp-action="Index" class="pf-order-action-btn pf-order-action-btn--secondary">
                    <i class="bi bi-grid me-2"></i>
                    <span>Continue Shopping</span>
                </a>
            </div>
        </div>

        <div class="pf-order-success-card">
            <div class="pf-order-success-card-head">
                <div>
                    <div class="pf-order-success-card-kicker">Just ordered</div>
                    <h2 class="pf-order-success-card-title">Products in this order</h2>
                </div>

                <div class="pf-order-success-card-total">
                    Total: <strong>@Eur(Model.TotalAmount)</strong>
                </div>
            </div>

            <div class="pf-order-success-items">
                @foreach (var item in Model.Items)
                {
                    <div class="pf-order-success-item">
                        <div class="pf-order-success-item-left">
                            <div class="pf-order-success-thumb-wrap">
                                @* Проверка за Picture, за да избегнем грешки CS0117 *@
                                @if (!string.IsNullOrWhiteSpace(item.Picture))
                                {
                                    <img src="@item.Picture" alt="@item.ProductName" class="pf-order-success-thumb" />
                                }
                                else
                                {
                                    <div class="pf-order-success-thumb-placeholder">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                            </div>

                            <div>
                                <div class="pf-order-success-product-name">@item.ProductName</div>
                                <div class="pf-order-success-product-meta">
                                    Quantity: @item.Quantity
                                    @if (item.Discount > 0)
                                    {
                                        <span class="pf-order-success-discount">• -@item.Discount.ToString("0.##")%</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="pf-order-success-item-right">
                            <div class="pf-order-success-price-line">
                                <span>Unit price</span>
                                <strong>@Eur(item.UnitPrice)</strong>
                            </div>
                            <div class="pf-order-success-price-line">
                                <span>Subtotal</span>
                                <strong class="pf-order-success-subtotal">@Eur(item.Subtotal)</strong>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@* Поставяш това най-отдолу в CartSuccess.cshtml *@

<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@@emailjs/browser@3/dist/email.min.js"></script>
<script type="text/javascript">
    (function() {
        // Инициализация - двойно @@, за да не го мисли Razor за C# променлива
        emailjs.init("gmtEXQ9LVkgWAUxxA");
    })();

    window.onload = function() {
        let productsSummary = "";
    @foreach (var item in Model.Items)
    {
        <text>productsSummary += "🏎️ @item.ProductName (x@item.Quantity) - @Eur(item.Subtotal)\\n";</text>
    }

        // Данни за КЛИЕНТА
        const clientParams = {
            user_name: "@User.Identity?.Name",
            // ПРЕМАХВАМЕ текста "user_email: " от стойността!
            user_email: "@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value",
            order_id: "@Model.OrderGroupId",
            products_summary: productsSummary,
            total_price: "@Eur(Model.TotalAmount)",
            message: "Thank you for your order at F1 Store!"
        };

       // Данни за АДМИНА (Теб)
        const adminParams = {
            // ТУК Е КЛЮЧЪТ: Слагаме твоя имейл в полето, което шаблонът чете
            user_email: "m.todorov2905@gmail.com",
            user_name: "ADMIN NOTIFICATION",
            order_id: "@Model.OrderGroupId",
            products_summary: "НОВА ПОРЪЧКА:\n" + productsSummary,
            total_price: "@Eur(Model.TotalAmount)",
            message: "Клиентът @User.Identity?.Name току-що направи поръчка."
        };

        // 1. Изпращане до КЛИЕНТА (ползва template_127whdh)
        emailjs.send("service_yxpydzl", "template_127whdh", clientParams)
            .then(function() {
                console.log('Client notified!');
            }, function(error) {
                console.error('Client email failed:', error);
            });

        // Изпращане до АДМИНА
        emailjs.send("service_yxpydzl", "template_127whdh", adminParams)
            .then(function() {
                console.log('Admin notified successfully!');
            });
    };
</script>