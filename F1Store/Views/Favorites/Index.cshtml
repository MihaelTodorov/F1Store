@model F1Store.Models.Favorite.FavoriteVM

<div class="container py-5 min-vh-100">
    <div class="mb-5">
        <h1 class="f1-font text-white m-0 text-uppercase" style="border-left: 5px solid var(--f1-red); padding-left: 15px;">
            My <span class="text-danger">Paddock</span>
        </h1>
        <p class="text-secondary f1-font small mt-2">YOUR PERSONAL COLLECTION OF TRACK-READY GEAR</p>
    </div>

    @if (Model.Items == null || !Model.Items.Any())
    {
        <div class="text-center py-5 border border-secondary border-dashed">
            <i class="bi bi-heart text-secondary" style="font-size: 4rem; opacity: 0.3;"></i>
            <h3 class="f1-font text-white mt-4">YOUR PADDOCK IS EMPTY</h3>
            <p class="text-secondary mb-4">Start exploring the store to add your favorite team gear here.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-danger f1-font px-5 rounded-0">
                BROWSE PRODUCTS
            </a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">
            @foreach (var item in Model.Items)
            {
                <div class="col">
                    <div class="card h-100 bg-dark text-white border-secondary rounded-0 product-card shadow-lg overflow-hidden">

                        <div class="bg-white p-4 text-center d-flex align-items-center justify-content-center" style="height: 220px;">
                            <img src="@item.Picture" alt="@item.ProductName" class="img-fluid" style="max-height: 100%; object-fit: contain;" />
                        </div>

                        <div class="card-body d-flex flex-column p-4" style="background: linear-gradient(180deg, #1e1e28 0%, #15151e 100%);">
                            <h6 class="card-title fw-bold text-uppercase mb-3 flex-grow-1 f1-font" style="letter-spacing: 0.5px; line-height: 1.4;">
                                @item.ProductName
                            </h6>

                            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top border-secondary border-opacity-50">
                                <div class="f1-font fs-5 fw-bold text-danger">
                                    @item.Price.ToString("F2")€
                                </div>

                                <div class="d-flex gap-2">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                                       class="btn btn-outline-light rounded-0" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <form asp-action="Remove" asp-route-productId="@item.ProductId" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger rounded-0" title="Remove from Paddock">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    :root {
        --f1-red: #e10600;
    }

    .f1-font {
        font-family: 'Orbitron', sans-serif;
    }

    
    .product-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(225, 6, 0, 0.25) !important;
            border-color: var(--f1-red) !important;
        }

    .border-dashed {
        border-style: dashed !important;
        background: rgba(255, 255, 255, 0.02);
    }

    .btn-danger {
        background-color: var(--f1-red);
        border-color: var(--f1-red);
    }

        .btn-danger:hover {
            background-color: #ff1e1e;
            border-color: #ff1e1e;
            box-shadow: 0 0 15px rgba(225, 6, 0, 0.4);
        }

    .btn-outline-danger:hover {
        background-color: var(--f1-red);
        border-color: var(--f1-red);
    }
</style>