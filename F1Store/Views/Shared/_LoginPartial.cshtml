@using Microsoft.AspNetCore.Identity
@using F1Store.Infrastructure.Data.Domain
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center flex-row">
    @if (SignInManager.IsSignedIn(User))
    {
        <style>
            #f1-user-nav {
                position: relative;
            }

                #f1-user-nav .dropdown-menu {
                    position: absolute !important;
                    right: 0 !important;
                    left: auto !important;
                    top: 100% !important;
                    min-width: 200px;
                    background-color: #1e1e2d !important;
                    border: 1px solid #e10600 !important;
                    border-radius: 0 !important;
                    margin-top: 10px !important;
                    z-index: 1050;
                }

                /* Пълна забрана за дефолтни сини/сиви фонове */
                #f1-user-nav .nav-link.dropdown-toggle,
                #f1-user-nav .nav-link.dropdown-toggle:focus,
                #f1-user-nav .nav-link.show {
                    background-color: transparent !important;
                    color: white !important;
                    box-shadow: none !important;
                    border: none !important;
                }

                #f1-user-nav .dropdown-item {
                    color: white !important;
                    font-family: 'Orbitron', sans-serif;
                    transition: 0.2s;
                }

                    #f1-user-nav .dropdown-item:hover {
                        background-color: #e10600 !important;
                        color: white !important;
                    }

            .cart-wrapper {
                margin-right: 20px;
                display: flex;
                align-items: center;
            }
        </style>

        @* --- КОЛИЧКА (View Component) --- *@
        <li class="nav-item cart-wrapper">
            <div id="cart-container">
                @await Component.InvokeAsync("CartSummary")
            </div>
        </li>

        @* --- ПОТРЕБИТЕЛСКО МЕНЮ --- *@
        <li class="nav-item dropdown" id="f1-user-nav">
            <a class="nav-link dropdown-toggle f1-font small text-white border-0 shadow-none d-flex align-items-center"
               href="#" id="f1UserDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-circle me-2 fs-5 text-danger"></i>
                @User.Identity?.Name
            </a>

            <ul class="dropdown-menu dropdown-menu-end shadow-lg" aria-labelledby="f1UserDropdown">
                <li>
                    <a class="dropdown-item small f1-font py-2" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <i class="bi bi-person me-2 text-danger"></i>PROFILE
                    </a>
                </li>
                <li><hr class="dropdown-divider bg-danger opacity-50"></li>
                <li>
                    <a class="dropdown-item small f1-font py-2" asp-area="" asp-controller="Order" asp-action="MyOrders">
                        <i class="bi bi-box-seam me-2 text-danger"></i>MY ORDERS
                    </a>
                </li>
                <li><hr class="dropdown-divider bg-danger opacity-50"></li>
                <li>
                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item text-danger fw-bold small f1-font w-100 text-start py-2">
                            <i class="bi bi-box-arrow-right me-2"></i>LOGOUT
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item d-flex gap-2">
            <a class="nav-link f1-font small nav-register-btn border border-danger px-3 py-1" asp-area="Identity" asp-page="/Account/Login">LOGIN</a>
            <a class="nav-link f1-font small nav-register-btn border border-danger px-3 py-1" asp-area="Identity" asp-page="/Account/Register">REGISTER</a>
        </li>
    }
</ul>