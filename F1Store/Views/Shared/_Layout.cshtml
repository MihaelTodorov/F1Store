<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - F1Store</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@500;700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --f1-red: #e10600;
            --f1-black: #15151e;
        }

        body {
            font-family: 'Rajdhani', sans-serif;
            background-color: var(--f1-black);
            color: white;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .f1-font {
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* NAVBAR */
        .navbar {
            border-bottom: 2px solid var(--f1-red);
            background: var(--f1-black);
            padding: 10px 0;
        }

        .brand-trigger {
            cursor: pointer;
            display: flex;
            align-items: center;
            text-decoration: none !important;
        }

        .navbar-brand {
            font-weight: 900;
            font-size: 1.4rem;
            color: var(--f1-red) !important;
            margin-left: 10px;
        }

        .cart-link {
            color: white !important;
            text-decoration: none;
            display: flex;
            align-items: center;
            transition: 0.3s;
        }

            .cart-link:hover {
                color: var(--f1-red) !important;
            }

        /* OFFCANVAS MENU */
        .offcanvas {
            background: var(--f1-black);
            border-right: 2px solid var(--f1-red);
            width: 280px;
        }

        .sidebar-link {
            font-family: 'Orbitron', sans-serif;
            padding: 15px 20px;
            display: block;
            color: #fff;
            text-decoration: none;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

            .sidebar-link:hover {
                background: var(--f1-red);
                padding-left: 30px;
            }

        footer {
            padding: 15px 0;
            background: #0b0b10;
            border-top: 1px solid rgba(255,255,255,0.1);
            margin-top: auto;
        }

        .nav-register-btn {
            background-color: var(--f1-red) !important;
            color: white !important;
            font-weight: bold;
            transition: 0.3s;
        }

            .nav-register-btn:hover {
                background-color: white !important;
                color: var(--f1-red) !important;
            }

        /* CUSTOM TOAST STYLE */
        .f1-toast {
            background-color: #1e1e2d !important;
            border-radius: 0 !important;
            border-left: 5px solid var(--f1-red) !important;
            color: white !important;
        }
    </style>
</head>
<body>

    <header>
        <nav class="navbar navbar-dark sticky-top">
            <div class="container-fluid px-3">
                <div class="brand-trigger" data-bs-toggle="offcanvas" data-bs-target="#f1Menu">
                    <i class="bi bi-list fs-2 text-white"></i>
                    <span class="navbar-brand f1-font">F1<span class="text-white">STORE</span></span>
                </div>

                <div class="d-flex align-items-center gap-3">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <div class="cart-link">
                            @await Component.InvokeAsync("CartSummary")
                        </div>

                        <div class="dropdown ms-2">
                            <a class="nav-link dropdown-toggle f1-font small text-white" href="#" data-bs-toggle="dropdown">
                                @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark border-danger rounded-0 shadow-lg">
                                <li><a class="dropdown-item small" asp-area="Identity" asp-page="/Account/Manage/Index">PROFILE</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                        <button type="submit" class="dropdown-item text-danger fw-bold small">LOGOUT</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex gap-2">
                            <a class="nav-link f1-font small nav-register-btn border border-danger px-3 py-1"
                               asp-area="Identity" asp-page="/Account/Login">LOGIN</a>

                            <a class="nav-link f1-font small nav-register-btn border border-danger px-3 py-1"
                               asp-area="Identity" asp-page="/Account/Register">REGISTER</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="offcanvas offcanvas-start text-white" id="f1Menu">
        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="f1-font text-danger m-0">Menu</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-0">
            <a class="sidebar-link" asp-controller="Home" asp-action="Index">HOME</a>
            <a class="sidebar-link" asp-controller="Product" asp-action="Index">STORE</a>
            <a class="sidebar-link" asp-controller="Home" asp-action="Contact">CONTACTS</a>
            <a class="sidebar-link" asp-controller="Favorites" asp-action="Index">FAVORITES</a>

            @if (User.IsInRole("Administrator"))
            {
                <div class="p-3 text-secondary fw-bold small bg-dark">ADMIN</div>
                <a class="sidebar-link" asp-controller="Order" asp-action="Index">ORDERS</a>
                <a class="sidebar-link" asp-controller="Statistic" asp-action="Index">STATISTICS</a>
                <a class="sidebar-link" asp-controller="Client" asp-action="Index">CLIENTS</a>
            }
        </div>
    </div>

    <main role="main" class="container-fluid px-4 mt-4 flex-grow-1">
        @RenderBody()
    </main>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 2000">
        <div id="f1Toast" class="toast f1-toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body f1-font">
                    <span id="toastMessage"></span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <footer class="text-center">
        <div class="container">
            <p class="text-secondary mb-1" style="font-size: 0.7rem;">&copy; 2026 F1 STORE. NOT OFFICIAL.</p>
            <a asp-controller="Home" asp-action="Policy" class="text-danger text-decoration-none small fw-bold">PRIVACY POLICY</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('f1Toast');
                var msg = "@(TempData["SuccessMessage"] ?? TempData["ErrorMessage"])";
                var isError = @(TempData["ErrorMessage"] != null ? "true" : "false");

                document.getElementById('toastMessage').innerText = msg;

                if (isError) {
                    toastEl.style.borderLeftColor = "orange"; // Или друг цвят за грешка
                }

                var toast = new bootstrap.Toast(toastEl, { delay: 3000 });
                toast.show();
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>