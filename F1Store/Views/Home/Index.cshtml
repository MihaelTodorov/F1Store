@{
    ViewData["Title"] = "F1 Store - 2026 Official Grid";
}

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;700&display=swap" rel="stylesheet">

<div id="f1HeroCarousel" class="carousel slide carousel-fade mb-5 shadow-lg" data-bs-ride="carousel" data-bs-interval="4000" data-bs-pause="false">
    <div class="carousel-inner custom-f1-clip">
        <div class="carousel-item active">
            <div class="hero-slide-bg" style="background-image: url('https://f1store.formula1.com/content/ws/all/10fc32f4-33cd-4bb9-9558-18cef3f540a3__1370X450.png');">
                <div class="hero-overlay">
                    <div class="container-fluid h-100 px-md-5">
                        <div class="row h-100 align-items-center">
                            <div class="col-lg-5 col-md-8 slide-content animate-slide-in ms-md-4">
                                <span class="badge bg-danger f1-font mb-2 px-3 py-2">NEW ERA: 2026</span>
                                <h1 class="display-1 f1-font fw-900 text-white mb-0 tracking-tighter">THE NEW</h1>
                                <h1 class="display-1 f1-font fw-900 text-danger mb-4 tracking-tighter">GENERATION</h1>
                                <p class="lead text-white mb-5 hero-text-shadow max-w-400">
                                    The grid is set. Audi and Cadillac join the fight. Explore the official merchandise of the 2026 season.
                                </p>
                                <a asp-controller="Product" asp-action="Index" class="btn btn-danger btn-lg f1-font rounded-0 px-5 py-3 shadow-red">EXPLORE ALL GEAR</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container position-relative z-3">
    <div class="section-head text-center mb-5">
        <h2 class="f1-font text-white display-4 uppercase mb-2">The <span class="text-danger">2026</span> Grid</h2>
        <div class="red-divider mx-auto"></div>
        <p class="text-secondary mt-3">Select a team to view their official collection</p>
    </div>

    <div class="row g-4 mb-5">
        @* Red Bull *@
        <div class="col-xl-3 col-lg-4 col-sm-6">
            <div class="team-card red-bull-theme">
                <div class="team-card-inner">
                    <div class="team-logo-wrap">
                        <img src="https://images.seeklogo.com/logo-png/40/2/red-bull-racing-f1-logo-png_seeklogo-406796.png" alt="Red Bull">
                    </div>
                    <div class="team-info">
                        <h5 class="f1-font">Red Bull Racing</h5>
                        <a asp-controller="Product" asp-action="Index" asp-route-team="Red Bull Racing" class="btn-shop-team">SHOP COLLECTION <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

        @* Ferrari *@
        <div class="col-xl-3 col-lg-4 col-sm-6">
            <div class="team-card ferrari-theme">
                <div class="team-card-inner">
                    <div class="team-logo-wrap">
                        <img src="https://vytvorsipotisk.cz/tshirtecommerce/generated-designs/t5vpqjeszfxm2r8li6nubdhyaco4970wkg13.png" alt="Ferrari">
                    </div>
                    <div class="team-info">
                        <h5 class="f1-font">Scuderia Ferrari</h5>
                        <a asp-controller="Product" asp-action="Index" asp-route-team="Scuderia Ferrari" class="btn-shop-team">SHOP COLLECTION <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </div>

