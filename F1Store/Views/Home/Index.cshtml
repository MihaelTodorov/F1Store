</div>

<style>
    :root {
        --f1-red: #e10600;
        --f1-black: #15151e;
        --f1-dark-grey: #1f1f27;
    }

    body {
        background-color: #0c0c12;
        color: white;
        font-family: 'Inter', sans-serif;
    }

    .f1-font {
        font-family: 'Orbitron', sans-serif;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .red-divider {
        width: 80px;
        height: 4px;
        background-color: var(--f1-red);
    }

    /* Hero Styling */
    .custom-f1-clip {
        clip-path: polygon(0 0, 100% 0, 100% 92%, 0% 100%);
    }

    .hero-slide-bg {
        height: 75vh;
        min-height: 550px;
        background-size: cover;
        background-position: center;
    }

    .hero-overlay {
        height: 100%;
        background: linear-gradient(90deg, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.6) 40%, transparent 100%);
    }

    /* Team Cards Design */
    .team-card {
        padding: 1px;
        background: rgba(255, 255, 255, 0.05);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        height: 100%;
        border-radius: 4px;
        position: relative;
        overflow: hidden;
    }

    .team-card-inner {
        background: var(--f1-black);
        padding: 2.5rem 1.5rem;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        border-bottom: 5px solid #333;
        transition: background 0.3s ease;
    }

    .team-logo-wrap {
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 2rem;
    }

        .team-logo-wrap img {
            max-width: 140px;
            max-height: 100px;
            filter: grayscale(1) brightness(2);
            transition: 0.4s ease;
        }

    .team-info {
        text-align: center;
    }

        .team-info h5 {
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
            color: #ddd;
        }

    .btn-shop-team {
        color: var(--f1-red);
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 2px;
        transition: 0.3s;
        border-bottom: 1px solid transparent;
        padding-bottom: 4px;
    }

    /* Hover Effects */
    .team-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

        .team-card:hover .team-logo-wrap img {
            filter: grayscale(0) brightness(1);
            transform: scale(1.1);
        }

    /* Team Colors */
    .red-bull-theme:hover .team-card-inner {
        border-color: #0600ef;
        background: linear-gradient(180deg, #15151e 0%, #000b2e 100%);
    }

    .ferrari-theme:hover .team-card-inner {
        border-color: #ef1a2d;
        background: linear-gradient(180deg, #15151e 0%, #2e0000 100%);
    }

    .mercedes-theme:hover .team-card-inner {
        border-color: #00a19c;
        background: linear-gradient(180deg, #15151e 0%, #001f1e 100%);
    }

    .mclaren-theme:hover .team-card-inner {
        border-color: #ff8700;
        background: linear-gradient(180deg, #15151e 0%, #2e1800 100%);
    }

    .aston-martin-theme:hover .team-card-inner {
        border-color: #006a4e;
        background: linear-gradient(180deg, #15151e 0%, #001f17 100%);
    }

    .alpine-theme:hover .team-card-inner {
        border-color: #0090ff;
        background: linear-gradient(180deg, #15151e 0%, #00102e 100%);
    }

    .audi-theme:hover .team-card-inner {
        border-color: #f50537;
        background: linear-gradient(180deg, #15151e 0%, #1a1a1a 100%);
    }

    .cadillac-theme:hover .team-card-inner {
        border-color: #ffc20e;
        background: linear-gradient(180deg, #15151e 0%, #211d00 100%);
    }

    .williams-theme:hover .team-card-inner {
        border-color: #005aff;
        background: linear-gradient(180deg, #15151e 0%, #000c2e 100%);
    }

    .racing-bulls-theme:hover .team-card-inner {
        border-color: #6692ff;
        background: linear-gradient(180deg, #15151e 0%, #001242 100%);
    }

    .haas-theme:hover .team-card-inner {
        border-color: #e6002b;
        background: linear-gradient(180deg, #15151e 0%, #1f1f1f 100%);
    }

    /* Animations */
    .animate-slide-in {
        animation: f1FadeLeft 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @@keyframes f1FadeLeft {
        from {
            opacity: 0;
            transform: translateX(-50px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@media (max-width: 992px) {
        .custom-f1-clip {
            clip-path: none;
        }

        .hero-slide-bg {
            height: 60vh;
        }

        .hero-overlay {
            background: rgba(0,0,0,0.8);
            text-align: center;
        }

        .slide-content {
            margin: 0 auto !important;
        }
    }
</style>