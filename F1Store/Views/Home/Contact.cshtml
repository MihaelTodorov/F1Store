@{
    ViewData["Title"] = "Contact Us";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="f1-font text-danger display-4">GET IN TOUCH</h1>
        <div class="f1-border-bottom mx-auto" style="width: 100px; height: 4px; background: #e10600;"></div>
        <p class="text-secondary mt-3 uppercase">Paddock Support & Fan Inquiries</p>
    </div>

    <div class="row g-5 justify-content-center">
        <div class="col-12 col-lg-4">
            <div class="card bg-dark border-secondary h-100 p-4 shadow-lg">
                <h3 class="f1-font text-white mb-4">CONTACT INFO</h3>

                <div class="d-flex align-items-center mb-4">
                    <div class="contact-icon me-3">
                        <i class="bi bi-geo-alt fs-3 text-danger"></i>
                    </div>
                    <div>
                        <div class="text-secondary small">HEADQUARTERS</div>
                        <div class="text-white fw-bold">Pernik, Bulgaria</div>
                    </div>
                </div>

                <div class="d-flex align-items-center mb-4">
                    <div class="contact-icon me-3">
                        <i class="bi bi-envelope fs-3 text-danger"></i>
                    </div>
                    <div>
                        <div class="text-secondary small">EMAIL</div>
                        <div class="text-white fw-bold">support@f1store.bg</div>
                    </div>
                </div>

                <div class="d-flex align-items-center mb-4">
                    <div class="contact-icon me-3">
                        <i class="bi bi-telephone fs-3 text-danger"></i>
                    </div>
                    <div>
                        <div class="text-secondary small">PHONE</div>
                        <div class="text-white fw-bold">+359 888 000 111</div>
                    </div>
                </div>

                <div class="mt-auto pt-4 border-top border-secondary text-center">
                    <h5 class="f1-font text-white mb-3">FOLLOW THE RACE</h5>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="#" class="text-white fs-4"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-white fs-4"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="text-white fs-4"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card bg-dark border-danger p-4 shadow-lg">
                <h3 class="f1-font text-white mb-4">SEND A MESSAGE</h3>
                <form id="contactForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-secondary small uppercase">Full Name (Auto)</label>
                            <input type="text" class="form-control bg-black border-secondary text-white rounded-0"
                                   value="@User.Identity?.Name" readonly disabled>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small uppercase">Your Email Address</label>
                            <input type="email" id="replyTo" class="form-control bg-black border-secondary text-white rounded-0"
                                   placeholder="max@redbull.com" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-secondary small uppercase">Subject</label>
                            <select id="msgSubject" class="form-select bg-black border-secondary text-white rounded-0">
                                <option selected>General Inquiry</option>
                                <option>Order Status</option>
                                <option>Returns & Refunds</option>
                                <option>Technical Issue</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label text-secondary small uppercase">Message</label>
                            <textarea id="msgBody" class="form-control bg-black border-secondary text-white rounded-0"
                                      rows="5" placeholder="Write your message here..." required></textarea>
                        </div>
                        <div class="col-12 mt-4">
                            <button type="submit" id="submitBtn" class="btn btn-danger w-100 f1-font py-3">
                                <i class="bi bi-send me-2"></i>SEND MESSAGE
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .f1-font {
        font-family: 'Orbitron', sans-serif;
        letter-spacing: 1px;
    }

    .uppercase {
        text-transform: uppercase;
    }

    .form-control:focus, .form-select:focus {
        background-color: #000;
        border-color: #e10600;
        box-shadow: 0 0 10px rgba(225, 6, 0, 0.3);
        color: white;
    }

    .card {
        background-color: rgba(21, 21, 30, 0.9) !important;
        backdrop-filter: blur(10px);
    }

    .btn-danger {
        background-color: #e10600;
        border: none;
        border-radius: 0;
        transition: 0.3s;
    }

        .btn-danger:hover {
            background-color: #ff1e1e;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(225, 6, 0, 0.4);
        }

    .contact-icon {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(225, 6, 0, 0.1);
        border-radius: 50%;
    }
</style>

<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@@emailjs/browser@3/dist/email.min.js"></script>

<script type="text/javascript">
    (function() {
        // Твоят Public Key
        emailjs.init("gmtEXQ9LVkgWAUxxA");
    })();

    document.getElementById('contactForm').addEventListener('submit', function(event) {
        event.preventDefault();

        const btn = document.getElementById('submitBtn');
        const originalBtnText = btn.innerHTML;

        btn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>SENDING...';
        btn.disabled = true;

        // Параметри според твоя шаблон template_sidu4z8
        const templateParams = {
            username: "@User.Identity?.Name",     // Използва името от Identity
            email: document.getElementById('replyTo').value,
            title: document.getElementById('msgSubject').value,
            message: document.getElementById('msgBody').value,
            time: new Date().toLocaleString('bg-BG')
        };

        // Изпращане чрез твоя Service ID и Template ID
        emailjs.send("service_yxpydzl", "template_sidu4z8", templateParams)
            .then(function() {
                // Красиво известие при успех
                Swal.fire({
                    title: 'MESSAGE SENT!',
                    text: 'Your inquiry has been delivered to our support team.',
                    icon: 'success',
                    background: '#15151e',
                    color: '#fff',
                    confirmButtonColor: '#e10600',
                    confirmButtonText: 'COPY THAT',
                    iconColor: '#e10600'
                });

                document.getElementById('contactForm').reset();
                btn.innerHTML = originalBtnText;
                btn.disabled = false;
            }, function(error) {
                // Красиво известие при грешка
                Swal.fire({
                    title: 'ENGINE FAILURE!',
                    text: 'We could not send your message. Please check the pits (console).',
                    icon: 'error',
                    background: '#15151e',
                    color: '#fff',
                    confirmButtonColor: '#e10600',
                    confirmButtonText: 'TRY AGAIN'
                });

                console.error('FAILED...', error);
                btn.innerHTML = originalBtnText;
                btn.disabled = false;
            });
    });
</script>