@model IEnumerable<F1Store.Models.Order.OrderIndexVM>

<div class="container-fluid py-4 px-md-5 bg-f1-main">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center">
            <div class="bg-danger px-2 py-1 text-white fw-bold me-3" style="font-size: 0.7rem; letter-spacing: 2px;">SECURE_LINK</div>
            <h2 class="f1-font text-white mb-0">ORDER <span class="text-danger">TELEMETRY</span></h2>
        </div>
        <div class="text-end">
            <span class="text-success blink">●</span> <span class="f1-font text-white-50" style="font-size: 0.8rem;">ACTIVE_STREAM</span>
        </div>
    </div>

    <div class="f1-table-card">
        <div class="table-responsive">
            <table class="table table-dark mb-0 align-middle">
                <thead>
                    <tr class="f1-font text-secondary border-bottom border-secondary" style="font-size: 0.7rem;">
                        <th class="ps-4 py-3">ID_TIMESTAMP</th>
                        <th>OPERATOR_IDENTITY</th>
                        <th>ASSET_ID</th>
                        <th class="text-center">QUANTITY</th>
                        <th class="text-center">GROSS_VALUE</th>
                        <th class="pe-4 text-end">SYSTEM_ACTION</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="f1-bulk-row">
                            <td class="ps-4 py-3 timestamp-cell">
                                @* Директно форматираме датата, без конвертиране *@
                                <div class="text-danger fw-bold">[@item.OrderDate.ToString("HH:mm:ss")]</div>
                                <div class="text-white-50 small">@item.OrderDate.ToString("dd.MM.yy")</div>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="user-strip me-2"></div>
                                    <div>
                                        <div class="fw-bolder text-white">@item.User.ToUpper()</div>
                                        <div class="text-danger" style="font-size: 0.6rem; font-weight: 900;">VERIFIED_USER</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="asset-block">@item.Product.ToUpper()</div>
                            </td>
                            <td class="text-center">
                                <div class="bulk-qty">x@(item.Quantity.ToString("D2"))</div>
                            </td>
                            <td class="text-center">
                                <div class="bulk-price">@item.TotalPrice.ToString("F2")€</div>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-controller="Order" asp-action="Details" asp-route-id="@item.Id" class="btn-f1-bulk">
                                    <span class="btn-inner">
                                        <i class="fas fa-terminal me-2"></i>INVESTIGATE
                                    </span>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-f1-main {
        background-color: #0c0c12;
        min-height: 100vh;
    }

    .f1-font {
        font-family: 'Orbitron', sans-serif;
        text-transform: uppercase;
    }

    .f1-table-card {
        background: #15151e;
        border: 2px solid #2a2a35;
        border-radius: 4px;
    }

    .f1-bulk-row {
        border-bottom: 1px solid #222;
        transition: 0.2s;
    }

        .f1-bulk-row:hover {
            background: rgba(255, 255, 255, 0.05);
        }

    
    .user-strip {
        width: 4px;
        height: 30px;
        background: var(--bs-danger);
    }

    .asset-block {
        background: #000;
        padding: 10px;
        border: 1px solid #333;
        font-size: 0.75rem;
        color: #aaa;
    }

    .bulk-qty {
        font-family: 'Orbitron';
        background: #222;
        padding: 5px 15px;
        border: 1px solid #444;
        color: #fff;
        display: inline-block;
    }

    .bulk-price {
        font-family: 'Orbitron';
        color: #e10600;
        font-size: 1.2rem;
        font-weight: 800;
    }

    
    .btn-f1-bulk {
        display: inline-block;
        padding: 8px 20px;
        background: transparent;
        border: 2px solid #444;
        color: #fff;
        font-family: 'Orbitron';
        font-size: 0.7rem;
        text-decoration: none;
        position: relative;
        transition: all 0.3s;
    }

        .btn-f1-bulk:hover {
            border-color: #e10600;
            background: #e10600;
            box-shadow: 0 0 15px rgba(225, 6, 0, 0.5);
        }

    .blink {
        animation: blinker 1s linear infinite;
    }

    @@keyframes blinker {
        50% {
            opacity: 0;
        }
    }
</style>