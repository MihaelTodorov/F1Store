@model IEnumerable<F1Store.Models.Order.OrderIndexVM>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-uppercase fw-bold border-start border-4 border-danger ps-3 text-white">My Orders</h1>
        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary btn-sm text-uppercase">Continue Shopping</a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 shadow-sm rounded bg-dark text-light">
            <i class="bi bi-cart-x display-1 text-secondary"></i>
            <p class="mt-3">You haven't placed any orders yet.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-12 mb-3">
                    <div class="card shadow-sm border-0 overflow-hidden" style="background: #15151e; color: white;">
                        <div class="row g-0 align-items-center">
                            <div class="col-md-2 text-center p-3 bg-white">
                                <img src="@item.Picture" class="img-fluid rounded" alt="@item.Product" style="max-height: 100px; object-fit: contain;">
                            </div>

                            <div class="col-md-10">
                                <div class="card-body">
                                    <div class="row align-items-center">
                                        <div class="col-md-4">
                                            <h5 class="card-title mb-1 text-truncate">@item.Product</h5>
                                            <small class="text-secondary">Ordered on: @item.OrderDate</small>
                                        </div>

                                        <div class="col-md-2 text-center">
                                            <div class="small text-secondary text-uppercase">Quantity</div>
                                            <div class="fw-bold">@item.Quantity</div>
                                        </div>

                                        <div class="col-md-2 text-center">
                                            <div class="small text-secondary text-uppercase">Price</div>
                                            <div>@item.Price.ToString("F2")€</div>
                                        </div>

                                        <div class="col-md-2 text-center">
                                            <div class="small text-secondary text-uppercase">Discount</div>
                                            <span class="badge bg-danger">-@item.Discount%</span>
                                        </div>

                                        <div class="col-md-2 text-end">
                                            <div class="small text-secondary text-uppercase">Total</div>
                                            <h5 class="text-danger fw-bold mb-0">@item.TotalPrice.ToString("F2")€</h5>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    body {
        background-color: #0b0b10;
    }

    .card {
        transition: transform 0.2s ease;
    }

        .card:hover {
            transform: scale(1.01);
            border-left: 4px solid #e10600 !important;
        }

    .text-secondary {
        color: #949498 !important;
    }
</style>