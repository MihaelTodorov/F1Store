@model F1Store.Models.Cart.CartCheckoutSuccessVM

@{
    ViewData["Title"] = "Order Success";
    
    string Eur(decimal x) => $"{x:0.00} €";
}

<div class="container text-center" style="margin-top: 100px; color: white;">
    <div class="mb-4">
        <i class="bi bi-trophy-fill text-warning" style="font-size: 5rem;"></i>
    </div>

    <h1 class="f1-font" style="letter-spacing: 2px;">ORDER RECEIVED!</h1>
    <p class="lead text-secondary">Your F1 gear is being prepared for shipment.</p>

    <div class="row justify-content-center mt-5">
        <div class="col-md-6 p-4" style="background: #15151e; border-left: 5px solid #e10600; border-radius: 4px;">
            <p class="text-uppercase small mb-1" style="color: #e10600;">Confirmation Details</p>
            <h4 class="mb-3">Order #@Model.OrderGroupId</h4>

            <div class="d-flex justify-content-between px-4 mb-2">
                <span>Status:</span>
                <span class="badge bg-success">Confirmed</span>
            </div>
            <div class="d-flex justify-content-between px-4 mb-4">
                <span>Total Amount:</span>
                <span class="fw-bold">@Eur(Model.TotalAmount)</span>
            </div>

            <hr class="border-secondary" />

            <div class="mt-4 d-flex gap-2 justify-content-center">
                <a asp-controller="Product" asp-action="Index" class="btn btn-danger btn-sm px-4 f1-font">
                    CONTINUE SHOPPING
                </a>
                <a asp-controller="Order" asp-action="MyOrders" class="btn btn-outline-light btn-sm px-4 f1-font">
                    MY ORDERS
                </a>
            </div>
        </div>
    </div>
</div>