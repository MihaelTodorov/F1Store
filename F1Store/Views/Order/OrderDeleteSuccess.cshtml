@{
    ViewData["Title"] = "ORDER REMOVED";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card bg-dark text-white border-danger shadow-lg p-5 text-center" style="max-width: 600px; background-color: #15151e !important;">
        <div class="mb-4">
            <div>
                <i class="bi bi-trash3-fill text-danger" style="font-size: 4rem;"></i>
            </div>
        </div>

        <h1 class="f1-font fw-bold mb-3" style="letter-spacing: 2px;">ORDER TERMINATED</h1>
        <div class="bg-danger" style="height: 3px; width: 60px; margin: 0 auto 20px;"></div>

        <p class="lead mb-4 opacity-75">
            The order has been successfully removed from the system.
            <br>
            <span class="text-success fw-bold">
                <i class="bi bi-box-seam me-2"></i>STOCK RESTORED SUCCESSFULLY
            </span>
        </p>

        <a asp-action="Index" class="btn btn-outline-light btn-lg px-5 border-2 fw-bold">
            BACK TO ORDERS
        </a>
    </div>
</div>