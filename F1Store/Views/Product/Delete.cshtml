@model F1Store.Models.Product.ProductDeleteVM

@{
    ViewData["Title"] = "Delete Product - F1 Store";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            @* Картата с лек стъклен ефект и червена граница *@
            <div class="card bg-dark text-white border-danger shadow-lg rounded-0" style="background: rgba(21, 21, 30, 0.95) !important; backdrop-filter: blur(10px);">

                <div class="card-header bg-danger text-white py-3 border-0">
                    <h4 class="f1-font m-0 text-center text-uppercase" style="letter-spacing: 1px;">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm Deletion
                    </h4>
                </div>

                <div class="card-body p-4 text-center">
                    <p class="text-secondary mb-4" style="font-size: 0.9rem;">
                        Are you sure you want to permanently remove this product? <br />
                        <span class="text-danger fw-bold uppercase" style="font-size: 0.75rem;">This action cannot be undone.</span>
                    </p>

                    @* --- PRODUCT PREVIEW --- *@
                    <div class="bg-black p-3 border border-secondary mb-4 position-relative">
                        <img src="@Model.Picture" alt="@Model.ProductName" class="img-fluid mb-3" style="max-height: 180px; object-fit: contain;" />
                        <h5 class="text-white f1-font mb-1 text-uppercase" style="font-size: 1rem;">@Model.ProductName</h5>
                        <div class="d-flex justify-content-center gap-2 mt-2">
                            <span class="badge bg-secondary rounded-0 uppercase" style="font-size: 0.7rem;">@Model.TeamName</span>
                            <span class="text-danger fw-bold">@Model.Price.ToString("F2") лв.</span>
                        </div>
                    </div>

                    @* --- DETAILS LIST --- *@
                    <div class="mb-4">
                        <div class="d-flex justify-content-between border-bottom border-secondary py-2 small">
                            <span class="text-secondary uppercase">Category:</span>
                            <span class="text-light">@Model.CategoryName</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom border-secondary py-2 small">
                            <span class="text-secondary uppercase">Stock Quantity:</span>
                            <span class="@(Model.Quantity > 0 ? "text-light" : "text-danger")">@Model.Quantity units</span>
                        </div>
                        <div class="d-flex justify-content-between border-bottom border-secondary py-2 small">
                            <span class="text-secondary uppercase">Discount Applied:</span>
                            <span class="text-danger fw-bold">@Model.Discount%</span>
                        </div>
                    </div>

                    @* --- ACTION BUTTONS --- *@
                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex gap-2">
                            <a asp-action="Index" class="btn btn-outline-light rounded-0 f1-font flex-grow-1 py-2">
                                <i class="bi bi-x-lg me-1"></i> CANCEL
                            </a>
                            <button type="submit" class="btn btn-danger rounded-0 f1-font flex-grow-1 py-2 shadow-sm">
                                <i class="bi bi-trash3-fill me-1"></i> DELETE
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --f1-red: #e10600;
    }

    .f1-font {
        font-family: 'Orbitron', 'F1-Regular', sans-serif;
    }

    .uppercase {
        text-transform: uppercase;
    }

    .btn-outline-light {
        border-color: #444;
        transition: all 0.3s ease;
    }

        .btn-outline-light:hover {
            background-color: white;
            color: black;
            border-color: white;
        }

    .btn-danger {
        background-color: var(--f1-red);
        border: none;
        transition: all 0.3s ease;
    }

        .btn-danger:hover {
            background-color: #b30500;
            transform: scale(1.02);
        }
</style>