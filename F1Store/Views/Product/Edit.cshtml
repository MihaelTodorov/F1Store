@model F1Store.Models.Product.ProductEditVM

@{
    ViewData["Title"] = "Edit Product - " + Model.ProductName;
}

<div class="container py-5 mt-4">
    @* --- HEADER --- *@
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="f1-font text-white m-0 text-uppercase" style="border-left: 5px solid #e10600; padding-left: 15px;">
                Edit <span class="text-danger">Product</span>
            </h1>
            <p class="text-secondary small mb-0 mt-1 uppercase">Modify details for: @Model.ProductName</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-0 f1-font px-4">
            <i class="bi bi-arrow-left me-2"></i>BACK TO LIST
        </a>
    </div>

    <form asp-action="Edit" method="post" class="row g-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-0 border-0 bg-danger text-white small" role="alert"></div>

        @* Важно: Скрито поле за ID, за да знае контролерът кой продукт обновяваме *@
        <input type="hidden" asp-for="Id" />

        @* --- LEFT COLUMN: CORE DATA --- *@
        <div class="col-lg-7">
            <div class="card bg-dark text-white border-secondary rounded-0 shadow-lg mb-4 hover-border-red">
                <div class="card-header border-secondary bg-black py-3">
                    <h5 class="f1-font m-0 text-uppercase small text-danger"><i class="bi bi-info-circle me-2"></i>General Information</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label asp-for="ProductName" class="form-label f1-font small text-secondary uppercase">Product Name</label>
                        <input asp-for="ProductName" class="form-control f1-input" />
                        <span asp-validation-for="ProductName" class="text-danger x-small"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="TeamId" class="form-label f1-font small text-secondary uppercase">Team</label>
                            <select asp-for="TeamId" class="form-select f1-input">
                                @foreach (var team in Model.Teams)
                                {
                                    <option value="@team.Id">@team.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label f1-font small text-secondary uppercase">Category</label>
                            <select asp-for="CategoryId" class="form-select f1-input">
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-0">
                        <label asp-for="Description" class="form-label f1-font small text-secondary uppercase">Description</label>
                        <textarea asp-for="Description" class="form-control f1-input" rows="6"></textarea>
                        <span asp-validation-for="Description" class="text-danger x-small"></span>
                    </div>
                </div>
            </div>

            <div class="card bg-dark text-white border-secondary rounded-0 shadow-lg hover-border-red">
                <div class="card-header border-secondary bg-black py-3">
                    <h5 class="f1-font m-0 text-uppercase small text-danger"><i class="bi bi-tags me-2"></i>Inventory & Pricing</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Price" class="form-label f1-font small text-secondary uppercase">Price</label>
                            <div class="input-group">
                                <input asp-for="Price" class="form-control f1-input" step="0.01" />
                                <span class="input-group-text bg-black border-secondary text-secondary">лв.</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger x-small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Discount" class="form-label f1-font small text-secondary uppercase">Discount</label>
                            <div class="input-group">
                                <input asp-for="Discount" class="form-control f1-input" min="0" max="100" />
                                <span class="input-group-text bg-black border-secondary text-secondary">%</span>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Quantity" class="form-label f1-font small text-secondary uppercase">Stock</label>
                            <input asp-for="Quantity" class="form-control f1-input" />
                            <span asp-validation-for="Quantity" class="text-danger x-small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* --- RIGHT COLUMN: GALLERY --- *@
        <div class="col-lg-5">
            <div class="card bg-dark text-white border-secondary rounded-0 shadow-lg sticky-top" style="top: 20px; z-index: 100;">
                <div class="card-header border-secondary bg-black py-3">
                    <h5 class="f1-font m-0 text-uppercase small text-danger"><i class="bi bi-image me-2"></i>Product Gallery</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label asp-for="Picture" class="form-label f1-font small text-danger uppercase fw-bold">Main Image URL</label>
                        <input asp-for="Picture" class="form-control f1-input border-danger img-input shadow-sm mb-3" data-preview="preview-main" />
                        <div class="text-center bg-black border border-secondary p-3" style="min-height: 250px; display: flex; align-items: center; justify-content: center;">
                            <img id="preview-main" src="@Model.Picture" class="img-fluid" style="max-height: 220px; object-fit: contain;" />
                        </div>
                    </div>

                    <hr class="border-secondary my-4" />

                    <div class="row g-3">
                        @foreach (var i in new[] { 2, 3, 4, 5 })
                        {
                            var propName = "Picture" + i;
                            var currentVal = Model.GetType().GetProperty(propName)?.GetValue(Model, null) as string;

                            <div class="col-6">
                                <label class="f1-font x-small text-secondary uppercase mb-1">Image @i</label>
                                <input name="@propName" id="@propName" value="@currentVal"
                                       class="form-control form-control-sm f1-input img-input mb-2"
                                       data-preview="preview-@i" />
                                <div class="preview-box text-center bg-black border border-secondary" style="height: 60px; display: flex; align-items: center; justify-content: center;">
                                    <img id="preview-@i" src="@currentVal" class="img-fluid h-100 @(string.IsNullOrEmpty(currentVal) ? "d-none" : "")" style="object-fit: contain;" />
                                    <i class="bi bi-image text-secondary @(!string.IsNullOrEmpty(currentVal) ? "d-none" : "")" id="icon-@i"></i>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-5 d-grid">
                        <button type="submit" class="btn btn-danger btn-lg rounded-0 f1-font py-3 shadow-red">
                            <i class="bi bi-save me-2"></i>SAVE CHANGES
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    .f1-input {
        background-color: #000 !important;
        color: #fff !important;
        border: 1px solid #333 !important;
        border-radius: 0 !important;
        transition: all 0.3s ease;
    }

        .f1-input:focus {
            border-color: #e10600 !important;
            box-shadow: 0 0 0 0.25rem rgba(225, 6, 0, 0.15) !important;
        }

    .shadow-red {
        box-shadow: 0 4px 15px rgba(225, 6, 0, 0.3);
    }

    .x-small {
        font-size: 0.75rem;
    }

    .uppercase {
        text-transform: uppercase;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.querySelectorAll('.img-input').forEach(input => {
            input.addEventListener('input', function() {
                const previewId = this.getAttribute('data-preview');
                const img = document.getElementById(previewId);
                const iconId = previewId.replace('preview-', 'icon-');
                const icon = document.getElementById(iconId);

                if (this.value && this.value.trim() !== '') {
                    img.src = this.value;
                    img.classList.remove('d-none');
                    if (icon) icon.classList.add('d-none');
                } else {
                    if (previewId !== 'preview-main') {
                        img.classList.add('d-none');
                        if (icon) icon.classList.remove('d-none');
                    }
                }
            });
        });
    </script>
}