@model F1Store.Models.Product.ProductDetailsVM

@{
    ViewData["Title"] = Model.ProductName + " - Details";
    var discountedPrice = Model.Price - (Model.Price * (decimal)Model.Discount / 100);
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

<style>
    body {
        background-color: #0b0b10;
        color: white;
        font-family: 'Titillium Web', sans-serif;
    }

    .details-card {
        background: #15151e;
        border-radius: 4px;
        border-top: 4px solid #e10600;
        padding: 30px;
        margin-top: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    
    .thumb-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        width: 80px;
    }

    .thumb-item {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border: 2px solid #2d2d37;
        cursor: pointer;
        opacity: 0.6;
        transition: 0.3s;
    }

        .thumb-item.active, .thumb-item:hover {
            border-color: #e10600;
            opacity: 1;
        }

    .main-img-container {
        background: #000;
        border: 1px solid #2d2d37;
        height: 500px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
    }

    .main-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
        image-rendering: -webkit-optimize-contrast;
    }

    
    .price-box {
        background: rgba(255,255,255,0.02);
        padding: 20px;
        border-bottom: 2px solid #e10600;
        margin-top: 15px;
        border-radius: 2px;
    }

    .current-price {
        font-size: 2.8rem;
        font-weight: 900;
        line-height: 1;
        letter-spacing: -1px;
    }

    .price-discounted {
        color: #e10600;
    }

    .price-normal {
        color: #fff;
    }

    .old-price {
        text-decoration: line-through;
        color: #6c757d;
        font-size: 1.1rem;
        margin-bottom: 5px;
    }

    .discount-badge {
        background: #e10600;
        color: white;
        font-weight: 700;
        padding: 4px 8px;
        margin-left: 10px;
        border-radius: 2px;
    }

    
    .top-info-section {
        text-align: center;
        margin-bottom: 25px;
    }

    .product-title {
        font-family: 'F1', 'Titillium Web', sans-serif;
        font-weight: 900;
        font-size: 2rem;
        line-height: 1.1;
        margin: 10px 0;
    }

    .product-description {
        font-size: 1rem;
        color: #ccc;
        line-height: 1.5;
    }

    .team-category {
        font-size: 0.85rem;
        color: #e10600;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1.5px;
    }

    
    .btn-f1 {
        text-transform: uppercase;
        font-weight: 800;
        border-radius: 2px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-add-cart {
        border: 1px solid #fff;
        color: #fff;
        background: transparent;
        flex: 2;
    }

        .btn-add-cart:hover {
            background: #fff;
            color: #000;
        }

    .btn-buy-now {
        background: #e10600;
        color: #fff;
        border: none;
        width: 100%;
    }

    .qty-group {
        display: flex;
        background: #0b0b10;
        border: 1px solid #2d2d37;
        height: 50px;
        flex: 0.8;
    }

    .qty-btn {
        background: transparent;
        border: none;
        color: #fff;
        width: 35px;
        cursor: pointer;
    }

    .qty-val {
        width: 100%;
        text-align: center;
        background: transparent;
        border: none;
        color: #fff;
        font-weight: bold;
        padding: 0;
        line-height: 50px;
        height: 50px;
        outline: none;
    }

        .qty-val::-webkit-outer-spin-button, .qty-val::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

    .divider {
        height: 1px;
        background: #2d2d37;
        margin: 20px 0;
    }
</style>

<div class="container mb-5">
    @Html.AntiForgeryToken()
    <div class="details-card">
        <div class="row">
            <div class="col-lg-7">
                <div class="d-flex gap-3">
                    <div class="thumb-list">
                        <img src="@Model.Picture" class="thumb-item active" onclick="updateMainImg('@Model.Picture', this)">
                        @foreach (var img in (new[] { Model.Picture2, Model.Picture3, Model.Picture4, Model.Picture5 }).Where(i => !string.IsNullOrEmpty(i)))
                        {
                            <img src="@img" class="thumb-item" onclick="updateMainImg('@img', this)">
                        }
                    </div>
                    <div class="main-img-container flex-grow-1">
                        <img id="mainImageDisplay" src="@Model.Picture" class="main-img">
                    </div>
                </div>

                <div class="price-box d-flex justify-content-between align-items-end">
                    <div>
                        @if (Model.Discount > 0)
                        {
                            <div class="old-price">€@Model.Price.ToString("F2")</div>
                            <div class="d-flex align-items-center">
                                <span class="current-price price-discounted">€@discountedPrice.ToString("F2")</span>
                                <span class="discount-badge">-@Model.Discount.ToString("0.##")% OFF</span>
                            </div>
                        }
                        else
                        {
                            <div class="current-price price-normal mt-2">€@Model.Price.ToString("F2")</div>
                        }
                    </div>
                    <div class="pb-2">
                        <div class="stock-indicator m-0" style="color: @(Model.Quantity > 0 ? "#28a745" : "#dc3545")">
                            In Stock (@Model.Quantity)
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 ps-lg-5 d-flex flex-column justify-content-between">
                <div class="top-info-section">
                    <div class="team-category">@Model.TeamName / @Model.CategoryName</div>
                    <h1 class="product-title">@Model.ProductName</h1>
                    <p class="product-description">@Model.Description</p>
                </div>

                <div class="d-grid gap-3">
                    @if (Model.Quantity > 0)
                    {
                        <div class="d-flex gap-2">
                            <div class="qty-group">
                                <button type="button" class="qty-btn" onclick="adjustQty(-1)">-</button>
                                <input type="number" id="qtyNumber" value="1" min="1" max="@Model.Quantity" class="qty-val">
                                <button type="button" class="qty-btn" onclick="adjustQty(1)">+</button>
                            </div>
                            <button class="btn btn-f1 btn-add-cart cart-ajax-btn" data-id="@Model.Id">
                                <i class="bi bi-cart-plus me-2 fs-5"></i> ADD TO CART
                            </button>
                        </div>

                        <form id="buyNowForm" asp-controller="Cart" asp-action="DirectCheckout" method="post" class="m-0">
                            <button type="submit" class="btn btn-f1 btn-buy-now">
                                <i class="bi bi-lightning-charge-fill me-2"></i> BUY IT NOW
                            </button>
                        </form>
                    }

                    <div class="divider"></div>
                    <div class="text-center">
                        <a asp-action="Index" class="back-to-store-link" style="color: #6c757d; text-decoration: none;">Back to Store</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        
        toastr.options = { "positionClass": "toast-bottom-right" };

        function updateMainImg(url, el) {
            $('#mainImageDisplay').fadeOut(100, function() {
                $(this).attr('src', url).fadeIn(100);
            });
            $('.thumb-item').removeClass('active');
            $(el).addClass('active');
        }

        function syncQty(val) {
            let max = @Model.Quantity;
            if (val < 1) val = 1;
            if (val > max) val = max;
            $('#qtyNumber').val(val);
        }

        function adjustQty(amt) {
            let currentVal = parseInt($('#qtyNumber').val()) || 1;
            syncQty(currentVal + amt);
        }

        $(document).ready(function() {
            const token = $('input[name="__RequestVerificationToken"]').val();

            $('#qtyNumber').on('input change', function() {
                syncQty(parseInt($(this).val()));
            });

            
            $('.cart-ajax-btn').on('click', function() {
                const btn = $(this);
                const productId = btn.data('id');
                const qty = $('#qtyNumber').val(); 

                $.post('/Cart/AddAjax', { productId: productId, quantity: qty, __RequestVerificationToken: token }, function(res) {
                    if (res.success) {
                        toastr.success("Item added to cart!");
                        $('#cart-count').text(res.count).hide().fadeIn(200);
                    }
                });
            });

            
            $('#buyNowForm').on('submit', function(e) {
                e.preventDefault();
                const form = this;
                const productId = @Model.Id;
                const qty = $('#qtyNumber').val();

                $.post('/Cart/AddAjax',
                    { productId: productId, quantity: qty, __RequestVerificationToken: token },
                    function(res) {
                        if (res.success) {
                            form.submit();
                        } else {
                            toastr.error(res.message || "Error during order.");
                        }
                    }
                );
            });
        });
    </script>
}