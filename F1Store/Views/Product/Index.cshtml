@model IEnumerable<F1Store.Models.Product.ProductIndexVM>

@{
    ViewData["Title"] = "F1 Store - Gear";
}

@functions {
    public string GetTeamColor(string teamName)
    {
        return teamName?.ToLower() switch
        {
            "red bull" => "#0600ef",
            "ferrari" => "#ef1a2d",
            "mercedes" => "#00a19c",
            "mclaren" => "#ff8700",
            "aston martin" => "#006a4e",
            "alpine" => "#0090ff",
            "audi" => "#f50537",
            "cadillac" => "#ffc20e",
            "williams" => "#005aff",
            "racing bulls" or "rb" => "#6692ff",
            "haas" => "#e6002b",
            _ => "#e10600"
        };
    }
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">

@Html.AntiForgeryToken()

<div class="container-fluid py-4">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <h2 class="f1-font text-white border-start border-danger border-4 ps-3 m-0">AVAILABLE GEAR</h2>

        @if (User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn btn-danger f1-font rounded-0 px-4 py-2">
                <i class="bi bi-plus-lg me-2"></i>CREATE NEW PRODUCT
            </a>
        }
    </div>

    <div class="card mb-5 border-secondary rounded-0 shadow-lg" style="background: #0b0b0f; position: relative; z-index: 1000;">
        <div class="card-body p-4">
            <form asp-controller="Product" asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-xl-4">
                    <label class="small text-secondary f1-font mb-2">SEARCH GEAR</label>
                    <input type="text" name="searchTerm" class="form-control f1-input" placeholder="Search..." value="@Context.Request.Query["searchTerm"]" />
                </div>
                <div class="col-xl-3">
                    <label class="small text-secondary f1-font mb-2">FILTER BY TEAM</label>
                    <select id="teamFilter" name="searchTeams" multiple class="filter-select">
                        <option value="Alpine">Alpine</option>
                        <option value="Aston Martin">Aston Martin</option>
                        <option value="Audi">Audi</option>
                        <option value="Cadillac">Cadillac</option>
                        <option value="Ferrari">Ferrari</option>
                        <option value="Haas">Haas</option>
                        <option value="McLaren">McLaren</option>
                        <option value="Mercedes">Mercedes</option>
                        <option value="Red Bull">Red Bull</option>
                        <option value="Racing Bulls">Racing Bulls</option>
                        <option value="Williams">Williams</option>
                    </select>
                </div>
                <div class="col-xl-3">
                    <label class="small text-secondary f1-font mb-2">FILTER BY CATEGORY</label>
                    <select id="categoryFilter" name="searchCategories" multiple class="filter-select">
                        <option value="Accessories">Accessories</option>
                        <option value="Auto Accessories">Auto Accessories</option>
                        <option value="Backpacks & Bags">Backpacks & Bags</option>
                        <option value="Collectibles & Memorabilia">Collectibles & Memorabilia</option>
                        <option value="Face Coverings">Face Coverings</option>
                        <option value="Footwear">Footwear</option>
                        <option value="Headwear">Headwear</option>
                        <option value="Home & Office">Home & Office</option>
                        <option value="Hoodies & Sweatshirts">Hoodies & Sweatshirts</option>
                        <option value="Jackets">Jackets</option>
                        <option value="Jerseys">Jerseys</option>
                        <option value="Pajamas & Underwear">Pajamas & Underwear</option>
                        <option value="Pants">Pants</option>
                        <option value="Polos">Polos</option>
                        <option value="Shirts & Sweaters">Shirts & Sweaters</option>
                        <option value="Shorts">Shorts</option>
                        <option value="Swim & Beach">Swim & Beach</option>
                        <option value="T-Shirts">T-Shirts</option>
                    </select>
                </div>
                <div class="col-xl-2">
                    <button type="submit" class="btn btn-danger w-100 f1-font rounded-0 py-2">APPLY</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div id="product-grid" class="row row-cols-1 row-cols-md-3 row-cols-xl-4 g-4" style="position: relative; z-index: 1;">
            @foreach (var item in Model)
            {
                var teamColor = GetTeamColor(item.TeamName);
                decimal discountedPrice = item.Price * (1 - (item.Discount / 100m));

                <div class="col product-item">
                    <div class="card h-100 bg-black text-white border-secondary rounded-0 product-card shadow-lg" style="--team-glow: @teamColor;">
                        <div class="img-wrapper position-relative p-0" style="height: 350px; overflow: hidden; background: #000;">
                            <a asp-action="Details" asp-route-id="@item.Id" class="stretched-link"></a>
                            <span class="badge position-absolute top-0 start-0 m-3 f1-font"
                                  style="background: #000; color: @teamColor; border: 1px solid @teamColor; z-index: 5;">
                                @item.TeamName
                            </span>
                            <img src="@item.Picture" class="w-100 h-100 product-img" style="object-fit: cover;" alt="@item.ProductName" />
                        </div>

                        <div class="card-body p-4 d-flex flex-column" style="background: #000; border-top: 1px solid #222;">
                            <div class="mt-auto">
                                <h6 class="text-uppercase fw-bold mb-2 text-white f1-font-name" style="font-size: 0.85rem; height: 40px; overflow: hidden;">@item.ProductName</h6>

                                <div class="pt-2 border-top border-secondary d-flex justify-content-between align-items-center">
                                    <div>
                                        @if (item.Quantity <= 0)
                                        {
                                            <span class="text-danger fw-bold fs-5 f1-font">OUT OF STOCK</span>
                                        }
                                        else if (item.Discount > 0)
                                        {
                                            <small class="text-secondary text-decoration-line-through d-block" style="font-size: 0.75rem;">@item.Price.ToString("F2") лв.</small>
                                            <span class="text-danger fw-bold fs-4 f1-font">€@discountedPrice.ToString("F2")</span>
                                        }
                                        else
                                        {
                                            <span class="text-white fw-bold fs-4 f1-font">€@item.Price.ToString("F2")</span>
                                        }
                                    </div>

                                    <div class="d-flex gap-2" style="z-index: 10; position: relative;">
                                        @if (User.IsInRole("Administrator"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-square border-warning text-warning"><i class="bi bi-pencil"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-square border-danger text-danger"><i class="bi bi-trash"></i></a>
                                        }

                                        <button type="button" class="btn btn-square fav-ajax-btn"
                                                data-id="@item.Id"
                                                data-is-fav="@(item.IsFavorite ? "true" : "false")">
                                            <i class="bi @(item.IsFavorite ? "bi-heart-fill text-danger" : "bi-heart text-white")"></i>
                                        </button>
                                        <button type="button" class="btn btn-square cart-ajax-btn" data-id="@item.Id" @(item.Quantity <= 0 ? "disabled" : "")>
                                            <i class="bi bi-cart-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div id="pagination-container" class="d-flex justify-content-center gap-2 mt-5 mb-4"></div>
    }
    else
    {
        <div class="row">
            <div class="col-12 d-flex justify-content-center align-items-center" style="min-height: 50vh;">
                <div class="text-center p-5 border border-secondary shadow-lg" style="background: #0b0b0f; max-width: 600px; width: 100%;">
                    <i class="bi bi-search text-secondary mb-4" style="font-size: 5rem; display: block;"></i>
                    <h2 class="f1-font text-white mb-3">NO GEAR MEETS YOUR REQUIREMENTS</h2>
                    <p class="text-secondary fs-5 mb-4">Try adjusting your filters or search term.</p>
                    <a href="@Url.Action("Index")" class="btn btn-outline-danger rounded-0 f1-font px-4 py-2">CLEAR ALL FILTERS</a>
                </div>
            </div>
        </div>
    }
</div>

<style>
    /* 1. Скриваме оригиналните селекти и Choices контейнера, докато не зареди */
    .filter-select {
        display: none !important;
    }

    .choices {
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    /* 2. ПЪЛНО премахване на скролбара от дропдаун менютата */
    .choices__list--dropdown,
    .choices__list--dropdown .choices__list {
        scrollbar-width: none !important;
        -ms-overflow-style: none !important;
    }

        .choices__list--dropdown::-webkit-scrollbar,
        .choices__list--dropdown .choices__list::-webkit-scrollbar {
            display: none !important;
            width: 0 !important;
        }

    html, body {
        scrollbar-width: none !important;
        -ms-overflow-style: none !important;
    }

        body::-webkit-scrollbar {
            display: none !important;
        }

    .f1-font {
        font-family: 'Orbitron', sans-serif;
        text-transform: uppercase;
    }

    .f1-font-name {
        font-family: 'Titillium Web', sans-serif;
        letter-spacing: 0.5px;
    }

    .choices__inner {
        background: #1a1a1a !important;
        border: 1px solid #333 !important;
        border-radius: 0 !important;
        color: white !important;
        min-height: 45px !important;
    }

    .choices__input {
        background-color: transparent !important;
        display: none !important;
    }

    .choices__list--multiple .choices__item {
        background-color: #e10600 !important;
        border: 1px solid #e10600 !important;
        font-family: 'Orbitron', sans-serif;
        text-transform: uppercase;
        font-size: 0.75rem;
    }

    .choices__list--dropdown {
        background: #111111 !important;
        border: 1px solid #444 !important;
        z-index: 1100 !important;
    }

    .choices__item--choice {
        background-color: #111 !important;
        color: #fff !important;
    }

        .choices__item--choice.is-highlighted {
            background-color: #e10600 !important;
        }

    .f1-input {
        background: #1a1a1a;
        color: #fff;
        border: 1px solid #333;
        border-radius: 0;
    }

    .btn-square {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #444;
        background: transparent;
        color: white;
        border-radius: 0;
    }

    .page-btn {
        width: 45px;
        height: 45px;
        border: 1px solid #444;
        background: #0b0b0f;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

        .page-btn.active {
            background: #e10600;
            border-color: #e10600;
        }

    .product-card {
        transition: 0.3s;
        border-bottom: 3px solid transparent !important;
    }

        .product-card:hover {
            transform: translateY(-8px);
            border-bottom-color: var(--team-glow) !important;
        }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function() {
            const choicesOptions = {
                removeItemButton: true,
                shouldSort: false,
                itemSelectText: '',
                placeholder: false,
                searchEnabled: false
            };

            const teamChoices = new Choices('#teamFilter', choicesOptions);
            const categoryChoices = new Choices('#categoryFilter', choicesOptions);

            // Показваме филтрите веднага след инициализация, за да няма премигване
            $('.choices').css('opacity', '1');

            const urlParams = new URLSearchParams(window.location.search);
            const teamParam = urlParams.get('team');

            if (teamParam) {
                const options = document.querySelectorAll('#teamFilter option');
                let foundValue = null;
                options.forEach(opt => {
                    if (opt.value.toLowerCase() === teamParam.toLowerCase()) {
                        foundValue = opt.value;
                    }
                });

                if (foundValue) {
                    teamChoices.setChoiceByValue(foundValue);
                    $('#teamFilter').closest('form').submit();
                }
            }

            const pageSize = 24;
            const $products = $('.product-item');
            const totalProducts = $products.length;
            const totalPages = Math.ceil(totalProducts / pageSize);
            const $paginationContainer = $('#pagination-container');

            function showPage(page) {
                $products.hide();
                const start = (page - 1) * pageSize;
                const end = start + pageSize;
                $products.slice(start, end).fadeIn(400);
                $('.page-btn').removeClass('active');
                $(`.page-btn[data-page="${page}"]`).addClass('active');
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }

            if (totalPages > 1) {
                for (let i = 1; i <= totalPages; i++) {
                    $paginationContainer.append(`<div class="page-btn" data-page="${i}">${i}</div>`);
                }
                $('.page-btn').on('click', function() {
                    showPage($(this).data('page'));
                });
                showPage(1);
            }

            const token = $('input[name="__RequestVerificationToken"]').val();
            toastr.options = { "positionClass": "toast-bottom-right", "progressBar": true };

            $('.fav-ajax-btn').on('click', function() {
                const btn = $(this);
                const icon = btn.find('i');
                const productId = btn.data('id');
                let isFav = btn.attr('data-is-fav') === "true";

                $.post(isFav ? '/Favorites/Remove' : '/Favorites/Add',
                    { productId: productId, __RequestVerificationToken: token },
                    function(res) {
                        if(res.success) {
                            if(!isFav) {
                                icon.removeClass('bi-heart text-white').addClass('bi-heart-fill text-danger');
                                btn.attr('data-is-fav', "true");
                                toastr.success("Added to favorites");
                            } else {
                                icon.removeClass('bi-heart-fill text-danger').addClass('bi-heart text-white');
                                btn.attr('data-is-fav', "false");
                                toastr.info("Removed from favorites");
                            }
                        }
                    }
                );
            });

            $('.cart-ajax-btn').on('click', function() {
                const btn = $(this);
                const productId = btn.data('id');
                $.post('/Cart/AddAjax', { productId: productId, __RequestVerificationToken: token }, function(res) {
                    if (res.success) {
                        toastr.success("Item added to cart!");
                        $('#cart-count').text(res.count).hide().fadeIn(200);
                    }
                });
            });
        });
    </script>
}