@{
    ViewData["Title"] = "Operation Success";
}

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@400;700&display=swap" rel="stylesheet">

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="success-card text-center shadow-lg">
        @* Анимирана икона за успех - чекмарк в стил F1 *@
        <div class="success-hex mx-auto mb-4">
            <i class="fas fa-check"></i>
        </div>

        <h1 class="f1-font fw-900 text-white mb-3">ACTION <span class="text-success">COMPLETED</span></h1>

        <div class="status-badge success mb-4">
            <span class="static-dot"></span>
            DATABASE SYNCHRONIZED
        </div>

        <p class="text-secondary mb-5 px-md-5">
            The user has been successfully removed from the <br>
            <strong>Official F1 Store Paddock Database</strong>.
        </p>

        <div class="action-zone p-4 bg-dark-soft">
            <a asp-action="Index" class="btn-f1-continue">
                CONTINUE TO LIST <i class="fas fa-chevron-right ms-2"></i>
            </a>
        </div>
    </div>
</div>

<style>
    :root {
        --f1-red: #e10600;
        --f1-teal: #00d2be; 
        --dark-soft: #15151e;
    }

    body {
        background-color: #0c0c12;
        color: white;
        font-family: 'Inter', sans-serif;
    }

    .f1-font {
        font-family: 'Orbitron', sans-serif;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    
    .success-card {
        background: var(--dark-soft);
        border: 2px solid #2a2a35;
        border-top: 5px solid var(--f1-teal);
        padding: 4rem 2rem;
        max-width: 600px;
        width: 100%;
        position: relative;
        border-radius: 4px;
    }

    
    .success-hex {
        width: 100px;
        height: 100px;
        background: var(--f1-teal);
        clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: #0c0c12;
        box-shadow: 0 0 30px rgba(0, 210, 190, 0.3);
        animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    @@keyframes scaleIn {
        from {
            transform: scale(0);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    
    .status-badge.success {
        background: rgba(0, 210, 190, 0.1);
        border: 1px solid var(--f1-teal);
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 0.7rem;
        font-family: 'Orbitron', sans-serif;
        color: var(--f1-teal);
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .static-dot {
        width: 8px;
        height: 8px;
        background: var(--f1-teal);
        border-radius: 50%;
    }

    
    .bg-dark-soft {
        background: #111;
        border-radius: 4px;
    }

    .btn-f1-continue {
        text-decoration: none !important;
        color: white;
        font-family: 'Orbitron', sans-serif;
        font-size: 0.85rem;
        border: 1px solid #444;
        padding: 12px 40px;
        transition: all 0.3s ease;
        display: inline-block;
    }

        .btn-f1-continue:hover {
            background: var(--f1-teal);
            color: #0c0c12;
            border-color: var(--f1-teal);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 210, 190, 0.2);
        }

    
    @@import url('https://cdnjs.cloudflare