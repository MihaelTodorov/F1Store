@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<style>
    .f1-card {
        background: #1f1f27;
        border-top: 3px solid var(--f1-red);
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .form-control {
        background-color: #2a2a35 !important;
        border: 1px solid #3d3d4d !important;
        color: white !important;
        border-radius: 0 !important;
    }

        .form-control:focus {
            border-color: var(--f1-red) !important;
            box-shadow: none !important;
        }

    .form-floating label {
        color: #999 !important;
    }

    .btn-f1-red {
        background-color: var(--f1-red);
        border: none;
        color: white;
        font-family: 'Orbitron', sans-serif;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 12px;
        transition: 0.3s;
    }

        .btn-f1-red:hover {
            background-color: white;
            color: var(--f1-red);
        }
</style>

<div class="container" style="margin-top: 50px; margin-bottom: 50px;">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="f1-card">
                <h1 class="f1-font text-center mb-4">@ViewData["Title"]</h1>
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <h5 class="f1-font text-secondary text-center mb-4" style="font-size: 0.9rem;">Join the Grid - Create Account</h5>
                    <hr class="border-secondary" />

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.FirstName" class="form-control" placeholder="John" />
                                <label asp-for="Input.FirstName"></label>
                                <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.LastName" class="form-control" placeholder="Doe" />
                                <label asp-for="Input.LastName"></label>
                                <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.UserName" class="form-control" placeholder="f1_fan" />
                        <label asp-for="Input.UserName"></label>
                        <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                        <label asp-for="Input.Email"></label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Address" class="form-control" placeholder="Street 123" />
                        <label asp-for="Input.Address"></label>
                        <span asp-validation-for="Input.Address" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.PhoneNumber" class="form-control" placeholder="088..." />
                        <label asp-for="Input.PhoneNumber"></label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.Password" class="form-control" placeholder="Password" />
                                <label asp-for="Input.Password"></label>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Confirm" />
                                <label asp-for="Input.ConfirmPassword"></label>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <button id="registerSubmit" type="submit" class="w-100 btn-f1-red mt-3">START ENGINES (REGISTER)</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}